    "@types/three": "^0.185.1",
    "i18next": "^26.3.6",
    "immer": "^11.1.15",
    "lucide-react": "^1.25.0",
    "react": "^19.2.8",
    "react-dom": "^19.2.8",
    "react-i18next": "^17.0.10",
    "react-markdown": "^10.1.0",
    "react-select": "^5.10.2",
    "remark-gfm": "^4.0.1",
    "sonner": "^2.0.7",
