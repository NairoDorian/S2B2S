    "@typescript-eslint/eslint-plugin": "^8.65.0",
    "@typescript-eslint/parser": "^8.65.0",
    "@vitejs/plugin-react": "^6.0.4",
    "eslint": "^10.7.0",
    "eslint-plugin-i18next": "^6.1.5",
    "prettier": "^3.9.6",
    "repomix": "^1.17.0",
    "typescript": "~7.0.2",
    "vite": "^8.1.5"
